{
  "name": "gsgfs-blog",
  "version": "1.0.6",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "GSGFs",
    "email": "gsgfs@gsgfs.moe",
    "url": "https://github.com/GSGFs7"
  },
  "packageManager": "pnpm@10.28.2",
  "description": "GSGFs blog",
  "homepage": "https://gsgfs.moe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GSGFs7/GSGFs-blog-frontend.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && pnpm dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build --webpack",
    "build:cloudflare": "opennextjs-cloudflare build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:cloudflare": "opennextjs-cloudflare deploy",
    "postinstall": "node scripts/copy-cap-wasm.cjs",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write --cache .",
    "prepare": "husky",
    "analyze": "ANALYZE=true pnpm build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@cap.js/server": "^4.0.5",
    "@cap.js/wasm": "^0.0.6",
    "@cap.js/widget": "^0.1.41",
